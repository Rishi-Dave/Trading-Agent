# Copy to .env and fill in. .env is gitignored — never commit real values (SPEC §2 T3).

# E*Trade developer credentials (https://developer.etrade.com — request sandbox key)
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=

# 1 = sandbox API base URL (default everywhere); 0 requires the sandbox-prod skill checklist
ETRADE_SANDBOX=1

# ntfy.sh topic for trade/breaker/kill-switch notifications.
# Use a long random string — ntfy topics are a public namespace.
NTFY_TOPIC=

# TOTP shared secret (RFC 6238) for remote kill-switch/breaker-reset
# triggering via ntfy (ADR-0003 point 5, SPEC §4.3). The topic above is NOT
# the auth credential (topics are guessable); a rotating code derived from
# this secret is. Required only if you run scripts/remote_listener.py.
# Generate with: uv run python scripts/generate_totp_secret.py
# (follow its instructions to also add the secret to an authenticator app).
NTFY_COMMAND_SECRET=
